{
  "manifest_version": 3,
  "name": "LinkedIn Reply Assistant",
  "version": "0.1.6",
  "description": "Draft LinkedIn replies, comments, follow-ups, and connection requests using OpenAI or a local LLM.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "options_page": "src/options.html",
  "action": {
    "default_title": "LinkedIn Reply Assistant",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/shared.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content.css"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ]
}
